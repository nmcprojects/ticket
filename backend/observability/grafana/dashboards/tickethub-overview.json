{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "TicketHub — Overview",
  "uid": "tickethub-overview",
  "schemaVersion": 39,
  "tags": ["tickethub"],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Services UP",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [], "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "targets": [ { "expr": "count(up{job=\"tickethub-services\"} == 1)", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s) by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [ { "expr": "sum by (service) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{service}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (s) by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [ { "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "{{service}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [ { "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "{{service}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Circuit breaker state (booking-service)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "description": "1 = current state. closed=healthy, open=tripped, half_open=trying again.",
      "targets": [ { "expr": "resilience4j_circuitbreaker_state", "legendFormat": "{{name}} - {{state}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Circuit breaker failure rate (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [ { "expr": "resilience4j_circuitbreaker_failure_rate", "legendFormat": "{{name}}", "refId": "A" } ]
    },
    {
      "type": "logs",
      "title": "Logs (all services TicketHub)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" },
      "targets": [ { "expr": "{job=\"tickethub\"}", "refId": "A" } ]
    }
  ]
}
